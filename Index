<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Portfolio of Nawaraj Siwakoti, full-stack developer specializing in Laravel and React">
<title>Nawaraj Siwakoti | Full-Stack Developer</title>

<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ===== Reset & Base ===== */
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:'Poppins', sans-serif; color:#1f2937; background:#f7f8fc; line-height:1.6; }
a { text-decoration:none; }
img { max-width:100%; display:block; }

/* ===== Navbar ===== */
nav {
  position: sticky; top:0; width:100%; background:#fff; z-index:1000;
  box-shadow:0 4px 15px rgba(0,0,0,0.05);
}
.nav-container { max-width:1200px; margin:auto; display:flex; justify-content:flex-start; align-items:center; padding:0.75rem 2rem; gap:2rem; }
.nav-links a {
  color:#1f2937; font-size:1.2rem; transition:color 0.3s;
}
.nav-links a:hover { color:#3b82f6; }

/* ===== Buttons ===== */
.btn {
  display:inline-block; padding:0.8rem 2rem;
  background:linear-gradient(135deg,#4f46e5,#3b82f6);
  color:#fff; border-radius:10px; font-weight:600;
  box-shadow:0 6px 15px rgba(0,0,0,0.15); transition:all 0.3s ease;
}
.btn:hover { transform:translateY(-3px); box-shadow:0 8px 25px rgba(0,0,0,0.2); }

/* ===== Hero ===== */
#hero {
  position:relative; height:100vh; display:flex; justify-content:center; align-items:center;
  text-align:center; background:linear-gradient(135deg,#e0e7ff,#f0f9ff); overflow:hidden;
}
.hero-container h1 { font-size:3.5rem; margin-bottom:1rem; color:#111827; }
.hero-container p { font-size:1.25rem; max-width:600px; margin:0 auto 2rem; color:#374151; }

/* Floating Shapes */
.shape { position:absolute; border-radius:50%; opacity:0.4; animation:float 6s ease-in-out infinite; }
.shape1 { width:200px; height:200px; background:#3b82f6; top:10%; left:5%; animation-delay:0s; }
.shape2 { width:150px; height:150px; background:#4f46e5; bottom:15%; right:10%; animation-delay:2s; }
.shape3 { width:100px; height:100px; background:#6366f1; top:40%; right:20%; animation-delay:4s; }
@keyframes float { 0%,100%{transform:translateY(0);}50%{transform:translateY(-20px);} }

/* ===== Sections ===== */
.section { padding:5rem 0; }
.section h2 { text-align:center; margin-bottom:3rem; font-size:2.5rem; color:#1f2937; position:relative; }
.section h2::after { content:""; width:60px; height:4px; background:#3b82f6; display:block; margin:0.5rem auto 0; border-radius:2px; }

/* ===== About ===== */
#about p { text-align:center; margin-bottom:2rem; max-width:700px; margin:auto; color:#4b5563; }
.experience { list-style:none; display:flex; flex-wrap:wrap; justify-content:center; gap:1rem; }
.experience li {
  background:#fff; padding:0.8rem 1.25rem; border-radius:12px;
  font-weight:500; color:#111827; box-shadow:0 6px 20px rgba(0,0,0,0.05);
  transition:transform 0.3s, box-shadow 0.3s, background 0.3s, color 0.3s;
}
.experience li:hover { transform:translateY(-5px); box-shadow:0 12px 30px rgba(0,0,0,0.1); background:#3b82f6; color:#fff; }

/* ===== Skills ===== */
.skills-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:2rem; }
.skill-category {
  background:#fff; padding:2rem; border-radius:16px;
  box-shadow:0 6px 25px rgba(0,0,0,0.05);
  transition:transform 0.4s, box-shadow 0.4s;
  opacity:0; transform:translateY(30px);
}
.skill-category h3 { margin-bottom:1rem; color:#3b82f6; }
.skill-category ul { list-style:none; }
.skill-category li { margin-bottom:0.5rem; color:#4b5563; }
.skill-category.show { opacity:1; transform:translateY(0); }

/* ===== Projects ===== */
.projects-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2.5rem; }
.project-card {
  background:#fff; padding:2rem; border-radius:18px;
  box-shadow:0 8px 30px rgba(0,0,0,0.05); transition:transform 0.4s, box-shadow 0.4s;
  opacity:0; transform:translateY(40px);
}
.project-card:hover { transform:translateY(-10px); box-shadow:0 12px 45px rgba(0,0,0,0.1); }
.project-card h3 { margin-bottom:0.75rem; color:#1f2937; }
.project-card p { color:#4b5563; }
.project-card.show { opacity:1; transform:translateY(0); }

/* ===== Contact ===== */
form { max-width:600px; margin:0 auto 2rem auto; display:flex; flex-direction:column; gap:1rem; }
form label { font-weight:600; color:#1f2937; }
form input, form textarea {
  padding:0.85rem 1rem; border-radius:10px; border:1px solid #d1d5db; font-size:1rem;
  transition:border-color 0.3s, box-shadow 0.3s;
}
form input:focus, form textarea:focus { border-color:#3b82f6; outline:none; box-shadow:0 4px 15px rgba(59,130,246,0.25); }

.social-links { text-align:center; margin-top:1.5rem; }
.social-links a { margin:0 1rem; color:#3b82f6; font-weight:500; font-size:1.25rem; transition:color 0.3s, transform 0.3s; }
.social-links a:hover { color:#6366f1; transform:translateY(-2px); }

/* ===== Footer ===== */
footer { background:#111827; color:#fff; text-align:center; padding:2rem 0; font-size:0.95rem; }

/* ===== Toast Notification ===== */
#toast {
  position: fixed; bottom: 2rem; right: 2rem;
  background: linear-gradient(135deg,#4ade80,#16a34a);
  color:#fff; padding:1rem 1.5rem; border-radius:10px;
  box-shadow:0 8px 20px rgba(0,0,0,0.2);
  opacity:0; transform:translateY(50px);
  transition: all 0.4s ease; font-weight:500; z-index:9999;
}
#toast.show { opacity:1; transform:translateY(0); }
#toast.error { background: linear-gradient(135deg,#f87171,#b91c1c); }

/* ===== Responsive ===== */
@media (max-width:768px){
  .hero-container h1{ font-size:2.5rem; }
  .hero-container p{ font-size:1rem; }
  .section h2{ font-size:2rem; }
  .nav-container { justify-content:center; gap:1rem; }
}
</style>
</head>
<body>

<!-- Navbar with Icons -->
<nav>
  <div class="nav-container">
    <a href="#hero"><i class="fas fa-home"></i></a>
    <a href="#about"><i class="fas fa-user"></i></a>
    <a href="#skills"><i class="fas fa-code"></i></a>
    <a href="#projects"><i class="fas fa-folder-open"></i></a>
    <a href="#contact"><i class="fas fa-envelope"></i></a>
  </div>
</nav>

<!-- Hero -->
<header id="hero">
  <div class="shape shape1"></div>
  <div class="shape shape2"></div>
  <div class="shape shape3"></div>
  <div class="container hero-container">
    <h1>Nawaraj Siwakoti</h1>
    <p>Full-Stack Developer | Laravel & React Enthusiast</p>
    <a href="#projects" class="btn">View My Work</a>
  </div>
</header>

<!-- About -->
<section id="about" class="section">
  <div class="container">
    <h2>About Me</h2>
    <p>I am a full-stack developer based in Nepal, specializing in modern web applications with Laravel and React. Passionate about clean code and performance-focused solutions.</p>
    <ul class="experience">
      <li>3+ years professional experience</li>
      <li>Strong backend & frontend expertise</li>
      <li>Worked on freelance & team projects</li>
    </ul>
  </div>
</section>

<!-- Skills -->
<section id="skills" class="section">
  <div class="container">
    <h2>Skills</h2>
    <div class="skills-grid">
      <div class="skill-category">
        <h3>Frontend</h3>
        <ul>
          <li>React.js</li>
          <li>HTML5 & CSS3</li>
          <li>JavaScript (ES6+)</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Backend</h3>
        <ul>
          <li>Laravel</li>
          <li>PHP & MySQL</li>
          <li>REST APIs</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Tools</h3>
        <ul>
          <li>Git & GitHub</li>
          <li>VS Code</li>
          <li>Postman</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Projects -->
<section id="projects" class="section">
  <div class="container">
    <h2>Projects</h2>
    <div class="projects-grid">
      <div class="project-card">
        <h3>Project One</h3>
        <p>A web app for task management with real-time updates.</p>
        <p><strong>Tech:</strong> Laravel, React, MySQL</p>
      </div>
      <div class="project-card">
        <h3>Project Two</h3>
        <p>E-commerce platform with payment integration and user dashboard.</p>
        <p><strong>Tech:</strong> Laravel, React, Stripe API</p>
      </div>
      <div class="project-card">
        <h3>Project Three</h3>
        <p>Portfolio website template for freelancers with responsive design.</p>
        <p><strong>Tech:</strong> HTML, CSS, JavaScript</p>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="section">
  <div class="container">
    <h2>Contact Me</h2>
    <form id="contactForm">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required>

      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>

      <label for="message">Message</label>
      <textarea id="message" name="message" rows="5" required></textarea>

      <button type="submit" class="btn">Send Message</button>
    </form>
    <div class="social-links">
      <a href="https://github.com/" target="_blank"><i class="fab fa-github"></i></a>
      <a href="https://linkedin.com/" target="_blank"><i class="fab fa-linkedin"></i></a>
      <a href="https://twitter.com/" target="_blank"><i class="fab fa-twitter"></i></a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer>
  <div class="container">
    <p>&copy; 2026 Nawaraj Siwakoti. All rights reserved.</p>
  </div>
</footer>

<!-- Toast -->
<div id="toast"></div>

<script>
// ===== Contact Form Toast =====
const contactForm = document.getElementById('contactForm');
const toast = document.getElementById('toast');
contactForm.addEventListener('submit', e => {
  e.preventDefault();
  const name = contactForm.name.value.trim();
  const email = contactForm.email.value.trim();
  const message = contactForm.message.value.trim();
  if(name && email && message){
    showToast('✅ Message sent successfully!');
    contactForm.reset();
  } else {
    showToast('⚠️ Please fill all fields', true);
  }
});
function showToast(message, isError=false){
  toast.textContent = message;
  toast.className = 'show' + (isError ? ' error':'');
  setTimeout(()=>{ toast.className = toast.className.replace('show',''); },3000);
}

// ===== Scroll Reveal =====
const observer = new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){ entry.target.classList.add('show'); }
  });
},{ threshold:0.1 });
document.querySelectorAll('.skill-category, .project-card').forEach(el=>{
  observer.observe(el);
});
</script>
</body>
</html>
